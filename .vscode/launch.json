{
    "configurations": [
        {
            "name": "Backend",
            "request": "launch",
            "type": "node-terminal",
            "command": "npm run build && npm start",
            "cwd": "${workspaceFolder}/backend"
        },
        {
            "name": "Frontend",
            "request": "launch",
            "type": "node-terminal",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}/frontend"
        }
    ],
    "compounds": [
        {
            "name": "Frontend/Backend",
            "configurations": ["Frontend", "Backend"],
            "stopAll": true
        }
    ]
}
